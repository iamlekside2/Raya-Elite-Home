# Copy to .env.local and fill in. NEVER commit .env.local.
# Public keys (exposed to the browser) are prefixed NEXT_PUBLIC_.

# Analytics
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_FB_PIXEL_ID=

# Live chat
NEXT_PUBLIC_TIDIO_KEY=

# Reviews
NEXT_PUBLIC_BIRDEYE_WIDGET_ID=

# Booking + maps
NEXT_PUBLIC_JOBBER_BOOKING_URL=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Lead & booking intake (server-side only)
# cPanel SMTP — use the noreply@ or info@ account credentials from cPanel Email Accounts
SMTP_HOST=mail.rayaelitehomesandofficescleaningservices.com
SMTP_PORT=465
SMTP_USER=noreply@rayaelitehomesandofficescleaningservices.com
SMTP_PASS=
INTAKE_EMAIL=intake@rayaelitehomesandofficescleaningservices.com
# Google Apps Script web-app URL that writes a row to the Lead & Booking Log sheet
GOOGLE_SHEETS_WEBHOOK_URL=
